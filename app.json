{
  "expo": {
    "name": "PocketQuartermaster",
    "slug": "pocket-quartermaster",
    "scheme": "pocketqm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.bigdadenergy39.PocketQuartermaster",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#1f3a5c"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8c658bfa-48f8-4298-9a54-c75c6ec3985c"
      }
    },
    "owner": "bigdadenergy39"
  }
}
